{
  "compilerOptions": {
    "outDir": "./dist/libs",
    "ignoreDeprecations": "6.0",
    "strict": false,
    "noImplicitAny": false,
    "strictNullChecks": false,
    "strictPropertyInitialization": false,
    "esModuleInterop": true,
    "experimentalDecorators":true,
    "declaration": true,
    "declarationMap": true,
    "composite": true,
    "skipLibCheck": true,
    "module": "commonjs",
    "target": "es2015",
    "noImplicitThis": true,
    "types": ["jest", "node"]
  },
  "include": ["**/*.ts"],
  "exclude": ["**/*.spec.ts"],
  "references": []
}